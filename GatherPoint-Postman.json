  "item": [
    {
      "name": "Auth",
      "item": [
        { "name": "Signup", "request": { "method": "POST", "url": "http://localhost:8080/api/auth/signup", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"John Doe\",\"email\": \"john@example.com\",\"password\": \"password123\",\"role\": \"EMPLOYEE\"}"} } },
        { "name": "Login", "request": { "method": "POST", "url": "http://localhost:8080/api/auth/login", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"email\": \"satyamkumarsinghjaisidih@gmail.com\",\"password\": \"admin123\"}"} } },
